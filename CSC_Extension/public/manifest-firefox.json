{
  "manifest_version": 3,
  "name": "CSC Extension",
  "description": "Capstone Project - Advanced Analytics Dashboard Extension",
  "version": "1.0.0",
  "action": {
    "default_popup": "popup.html",
    "default_title": "CSC Extension - Dashboard"
  },
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.instagram.com/*",
        "https://www.facebook.com/*",
        "https://x.com/*",
        "https://twitter.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": ["storage", "tabs", "scripting"],
  "host_permissions": [
    "http://localhost:8000/*",
    "https://www.instagram.com/*",
    "https://www.facebook.com/*",
    "https://x.com/*",
    "https://twitter.com/*"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "csc-extension@capstone.com",
      "strict_min_version": "109.0"
    }
  }
}
