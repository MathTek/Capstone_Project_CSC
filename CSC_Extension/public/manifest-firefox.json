{
  "manifest_version": 2,
  "name": "CSC Extension",
  "description": "Capstone Project - Advanced Analytics Dashboard Extension",
  "version": "1.0.0",
  "browser_action": {
    "default_popup": "popup.html",
    "default_title": "CSC Extension - Dashboard",
    "default_icon": "icon.svg"
  },
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.instagram.com/*",
        "https://www.facebook.com/*",
        "https://x.com/*",
        "https://twitter.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "storage",
    "tabs",
    "<all_urls>",
    "webRequest",
    "http://localhost:8000/*",
    "https://www.instagram.com/*",
    "https://www.facebook.com/*",
    "https://x.com/*",
    "https://twitter.com/*"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "csc-extension@capstone.com",
      "strict_min_version": "102.0"
    }
  },
  "content_security_policy": "script-src 'self' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; object-src 'self';"
}
